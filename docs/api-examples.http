# استدعاء تسجيل الدخول
POST http://localhost:3000/api/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

###

# جلب الأعمال (يحتاج توكن في الهيدر أو كوكي)
GET http://localhost:3000/api/businesses
Authorization: Bearer {{token}}

###

# جلب أقسام السايدبار لعمل معيّن
GET http://localhost:3000/api/businesses/1/sidebar-sections
Authorization: Bearer {{token}}

###

# جلب عناصر السايدبار
GET http://localhost:3000/api/businesses/1/sidebar-items
Authorization: Bearer {{token}}

###

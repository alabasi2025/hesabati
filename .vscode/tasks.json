{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open Simple Browser: حساباتي",
      "command": "${input:openSimpleBrowser}",
      "problemMatcher": []
    },
    {
      "label": "Open Simple Browser: فواتير المشتريات",
      "command": "${input:openSimpleBrowserPurchases}",
      "problemMatcher": []
    },
    {
      "label": "Backend: pnpm run dev",
      "type": "shell",
      "command": "pnpm run dev",
      "options": { "cwd": "${workspaceFolder}/backend", "env": {} },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Backend: db:push",
      "type": "shell",
      "command": "pnpm run db:push",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": [],
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Backend: db:seed",
      "type": "shell",
      "command": "pnpm run db:seed",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": [],
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Backend: db:generate",
      "type": "shell",
      "command": "pnpm run db:generate",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": [],
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Frontend: ng serve",
      "type": "shell",
      "command": "pnpm start",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Start All (Backend + Frontend)",
      "dependsOn": ["Backend: pnpm run dev", "Frontend: ng serve"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "openSimpleBrowser",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://localhost:4200"]
    },
    {
      "id": "openSimpleBrowserPurchases",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://localhost:4200/biz/1/purchase-invoices"]
    }
  ]
}

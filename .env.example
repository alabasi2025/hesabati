# ============================================================
# .env.example — hesabati environment variables
# Copy to .env and fill in values
# ============================================================

# Database
DATABASE_URL=postgresql://hesabati:your_password@localhost:5432/hesabati
POSTGRES_DB=hesabati
POSTGRES_USER=hesabati
POSTGRES_PASSWORD=your_strong_password_here

# JWT Security — MUST be a 64-character random string in production
# Generate with: openssl rand -hex 32
JWT_SECRET=your_64_char_random_secret_here

# Server
NODE_ENV=development
PORT=3000

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Backend port (for docker-compose)
BACKEND_PORT=3000

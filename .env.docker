# ===================== إعدادات Docker Compose =====================
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك

# كلمة مرور قاعدة البيانات (يجب تغييرها!)
DB_PASSWORD=StrongPassword123!

# مفتاح JWT (يجب توليد مفتاح عشوائي: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_HEX

# النطاقات المسموحة (فصل بفاصلة)
ALLOWED_ORIGINS=https://yourdomain.com

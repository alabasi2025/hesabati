# ===================== إعدادات قاعدة البيانات =====================
# يجب تغيير كلمة المرور في بيئة الإنتاج
DATABASE_URL=postgresql://postgres:YOUR_STRONG_PASSWORD@localhost:5432/hesabati

# ===================== إعدادات الأمان =====================
# مفتاح JWT - يجب توليد مفتاح عشوائي قوي: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_HEX

# ===================== إعدادات الخادم =====================
PORT=3000
NODE_ENV=production

# ===================== CORS - النطاقات المسموحة =====================
# فصل النطاقات بفاصلة - في الإنتاج استخدم النطاق الفعلي فقط
ALLOWED_ORIGINS=https://yourdomain.com

# ===================== إعدادات قاعدة البيانات المتقدمة =====================
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=20
DB_CONNECT_TIMEOUT=10

# ===================== إعدادات النسخ الاحتياطي =====================
BACKUP_DIR=/var/backups/hesabati
BACKUP_RETENTION_DAYS=30

# ===================== إعدادات السجلات =====================
LOG_LEVEL=info
LOG_DIR=/var/log/hesabati

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@shared": ["../shared/index.ts"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/__tests__", "src/engines/__tests__", "src/db/check-schema-match.ts",
    "src/db/add-account-types-sidebar.ts", "src/db/add-sidebar-salaries-section.ts",
    "src/db/check-account-ids.ts", "src/db/check-dashboard-data.ts",
    "src/db/check-operations.ts", "src/db/check-schema-runner.ts",
    "src/db/check-schema-tables.ts", "src/db/create-expense-categories-table.ts",
    "src/db/delete-all-operations.ts", "src/db/delete-template-operations.ts",
    "src/db/inspect-db.ts", "src/db/inspect-template.ts",
    "src/db/reset-sidebar.ts", "src/db/seed.ts", "src/db/seed_sidebar.ts",
    "src/db/seed-entities.ts", "src/db/journal-migrate.ts",
    "src/scripts"
  ]
}

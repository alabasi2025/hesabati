{
  "name": "hesabati-backend",
  "version": "1.0.0",
  "description": "نظام حساباتي - الخادم الخلفي",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:baseline": "tsx scripts/baseline-drizzle-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:reset": "tsx scripts/reset-database.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:fresh": "npm run db:reset && npm run db:push && npm run db:seed",
    "db:check": "tsx src/db/check-schema-match.ts",
    "check:tdad": "node ../.tdad/scripts/validate-workflows.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@orpc/openapi": "^1.4.0",
    "@orpc/server": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.5",
    "ws": "^8.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "@orpc/client": ">=1.13.6",
      "path-to-regexp": ">=8.0.0",
      "micromatch": ">=4.0.8"
    }
  }
}

{
  "openapi": "3.0.3",
  "info": {
    "title": "Hesabati API",
    "description": "نظام المحاسبة — واجهة برمجية شاملة لإدارة المعاملات المالية والمخازن والتقارير",
    "version": "10.0.0",
    "contact": {
      "name": "Hesabati Support",
      "url": "https://github.com/alabasi2025/hesabati"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Development"
    },
    {
      "url": "https://api.hesabati.com/api",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT (HS256)"
      }
    },
    "schemas": {
      "Voucher": {
        "type": "object",
        "required": [
          "bizId",
          "voucherType",
          "amount",
          "currency"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "bizId": {
            "type": "integer"
          },
          "voucherType": {
            "type": "string",
            "enum": [
              "receipt",
              "payment"
            ]
          },
          "amount": {
            "type": "number",
            "minimum": 0.01
          },
          "currency": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "unreviewed",
              "reviewed",
              "confirmed",
              "cancelled"
            ]
          },
          "sequenceNo": {
            "type": "string",
            "pattern": "^[A-Z]+-[0-9]{4}-[0-9]{6}$"
          }
        }
      },
      "PurchaseInvoice": {
        "type": "object",
        "required": [
          "bizId",
          "supplierId",
          "items"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "bizId": {
            "type": "integer"
          },
          "supplierId": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "confirmed",
              "cancelled"
            ]
          },
          "totalAmount": {
            "type": "number"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InvoiceItem"
            }
          }
        }
      },
      "InvoiceItem": {
        "type": "object",
        "required": [
          "itemId",
          "quantity",
          "unitPrice"
        ],
        "properties": {
          "itemId": {
            "type": "integer"
          },
          "quantity": {
            "type": "number",
            "minimum": 0
          },
          "unitPrice": {
            "type": "number",
            "minimum": 0
          }
        }
      },
      "Warehouse": {
        "type": "object",
        "required": [
          "bizId",
          "name"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "bizId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "location": {
            "type": "string"
          }
        }
      },
      "Fund": {
        "type": "object",
        "required": [
          "bizId",
          "name",
          "currency"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "bizId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "balance": {
            "type": "number"
          }
        }
      },
      "Partner": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "bizId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "customer",
              "supplier"
            ]
          },
          "balance": {
            "type": "number"
          }
        }
      },
      "Employee": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "bizId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "salary": {
            "type": "number"
          },
          "department": {
            "type": "string"
          }
        }
      },
      "AuditLog": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "userId": {
            "type": "integer"
          },
          "businessId": {
            "type": "integer"
          },
          "action": {
            "type": "string"
          },
          "tableName": {
            "type": "string"
          },
          "recordId": {
            "type": "integer"
          },
          "changes": {
            "type": "object"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "success",
          "message"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "minimum": 1
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "total": {
            "type": "integer"
          }
        }
      }
    }
  },
  "paths": {
    "/businesses/{bizId}/vouchers": {
      "get": {
        "summary": "قائمة السندات",
        "tags": [
          "Vouchers"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "قائمة السندات",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Voucher"
                  }
                }
              }
            }
          },
          "401": {
            "description": "غير مصرح",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "إنشاء سند جديد",
        "tags": [
          "Vouchers"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Voucher"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "تم الإنشاء بنجاح"
          },
          "400": {
            "description": "بيانات غير صالحة",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/businesses/{bizId}/purchase-invoices": {
      "get": {
        "summary": "قائمة فواتير المشتريات",
        "tags": [
          "Purchase Invoices"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "قائمة الفواتير",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PurchaseInvoice"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "إنشاء فاتورة مشتريات",
        "tags": [
          "Purchase Invoices"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PurchaseInvoice"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "تم الإنشاء"
          }
        }
      }
    },
    "/businesses/{bizId}/warehouses": {
      "get": {
        "summary": "قائمة المخازن",
        "tags": [
          "Warehouses"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "قائمة المخازن",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Warehouse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/businesses/{bizId}/funds": {
      "get": {
        "summary": "قائمة الصناديق",
        "tags": [
          "Funds"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "قائمة الصناديق",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Fund"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "إنشاء صندوق جديد",
        "tags": [
          "Funds"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Fund"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "تم الإنشاء"
          }
        }
      }
    },
    "/businesses/{bizId}/partners": {
      "get": {
        "summary": "قائمة الشركاء / العملاء / الموردين",
        "tags": [
          "Partners"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "قائمة الشركاء",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Partner"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/businesses/{bizId}/employees": {
      "get": {
        "summary": "قائمة الموظفين",
        "tags": [
          "Employees"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "قائمة الموظفين",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Employee"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/businesses/{bizId}/audit-log": {
      "get": {
        "summary": "سجل التدقيق",
        "tags": [
          "Audit"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "table",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "سجل التدقيق",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AuditLog"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/businesses/{bizId}/reporting/profit-loss": {
      "get": {
        "summary": "تقرير الأرباح والخسائر",
        "tags": [
          "Reporting"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "نتائج الأرباح والخسائر"
          }
        }
      }
    },
    "/businesses/{bizId}/reporting/trial-balance": {
      "get": {
        "summary": "ميزان المراجعة",
        "tags": [
          "Reporting"
        ],
        "parameters": [
          {
            "name": "bizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ميزان المراجعة"
          }
        }
      }
    }
  }
}